{
  "name": "@bobfrankston/gcal",
  "version": "0.1.52",
  "description": "Google Calendar CLI tool with ICS import support",
  "type": "module",
  "main": "gcal.js",
  "bin": {
    "gcal": "gcal.js",
    "gtask": "gtask.js"
  },
  "files": [
    "gcal.ts",
    "gcal.js",
    "gcal.js.map",
    "gcal.d.ts",
    "gcal.d.ts.map",
    "gtask.ts",
    "gtask.js",
    "gtask.js.map",
    "gtask.d.ts",
    "gtask.d.ts.map",
    "glib/**/*.ts",
    "glib/**/*.js",
    "glib/**/*.js.map",
    "glib/**/*.d.ts",
    "glib/**/*.d.ts.map",
    "tsconfig.json",
    "README.md",
    "gcal-credentials.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BobFrankston/gcal.git"
  },
  "scripts": {
    "postinstall": "node -e \"if(process.platform==='win32')console.log('\\nTip: run \\\"gcal assoc\\\" to associate .ics files with gcal')\"",
    "build": "tsc",
    "check": "tsc --noEmit",
    "prerelease:local": "git add -A && (git diff-index --quiet HEAD || git commit -m \"Pre-release commit\")",
    "preversion": "npm run build && git add -A",
    "release": "npmglobalize",
    "release:local": "npm run prerelease:local && npm version patch && npm publish --access public --ignore-scripts",
    "installer": "npm run release && npm install -g .",
    "old-release": "npm run prerelease:local && npm version patch && npm publish --access public",
    "old-installer": "npm run release && npm install -g ."
  },
  "keywords": [
    "google",
    "calendar",
    "ics",
    "ical",
    "oauth",
    "cli"
  ],
  "author": "Bob Frankston",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0"
  },
  "dependencies": {
    "@bobfrankston/oauthsupport": "^1.0.24",
    "clipboardy": "^5.3.1",
    "ical.js": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  ".dependencies": {
    "@bobfrankston/oauthsupport": "file:../../../projects/OAuth/OauthSupport",
    "clipboardy": "^5.3.1",
    "ical.js": "^2.1.0"
  },
  ".transformedSnapshot": {
    "dependencies": {
      "@bobfrankston/oauthsupport": "^1.0.24",
      "clipboardy": "^5.3.1",
      "ical.js": "^2.1.0"
    }
  }
}
